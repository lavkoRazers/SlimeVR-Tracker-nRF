/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>

&pinctrl {
	pwm0_default: pwm0_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 15)>;
			nordic,drive-mode = <NRF_DRIVE_D0S1>;
		};
	};

	pwm0_sleep: pwm0_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 15)>;
			low-power-enable;
		};
	};

	pwm1_default: pwm1_default {
		group1 {
			psels = <NRF_PIN_DISCONNECTED>;
		};
	};

	pwm1_sleep: pwm1_sleep {
		group1 {
			psels = <NRF_PIN_DISCONNECTED>;
			low-power-enable;
		};
	};

	spi3_default: spi3_default {
		group1 {
			/* ПИНЫ SPI ИЗМЕНЕНЫ ПОД КОНЦЕПТ ДРУГА */
			psels = <NRF_PSEL(SPIM_MISO, 0, 11)>, /* SDO = 011 */
					<NRF_PSEL(SPIM_MOSI, 0, 24)>, /* SDA = 024 */
					<NRF_PSEL(SPIM_SCK,  0, 22)>;  /* SCL = 022 */
		};
	};

	spi3_sleep: spi3_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_MISO, 0, 11)>,
					<NRF_PSEL(SPIM_MOSI, 0, 24)>,
					<NRF_PSEL(SPIM_SCK,  0, 22)>;
			low-power-enable;
		};
	};
};

/ {
	model = "promicro_uf2";
	compatible = "promicro_uf2";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	pwmleds {
		compatible = "pwm-leds";
		pwm_led0: pwm_led_0 {
			pwms = <&pwm0 0 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 6 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>; /* SW0 = 006 */
			label = "Push button switch 0";
		};
	};

	aliases {
		sw0 = &button0;
		pwm-led0 = &pwm_led0;
		imu = &imu_spi;
	};

	pwmclock: pwmclock {
		compatible = "pwm-clock";
		#clock-cells = <1>;
		pwms = <&pwm1 0 PWM_HZ(32768) PWM_POLARITY_NORMAL>;
	};

	battery-divider {
		compatible = "voltage-divider";
		status = "okay";
		/* Замер батареи через внутренний системный канал контроллера (VDDHDIV5) */
		io-channels = <&adc 12>;
		output-ohms = <1>;
		full-ohms = <5>;
	};

	zephyr,user {
		/* УПРАВЛЯЮЩИЕ ПИНЫ ИЗМЕНЕНЫ ПОД КОНЦЕПТ ДРУГА */
		vcc-gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>; /* 3V3 = 017 */
		gnd-gpios = <&gpio0 20 GPIO_OPEN_DRAIN>;  /* GND = 020 */
		int0-gpios = <&gpio0 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>; /* INT1 = 002 */
		clk-gpios = <&gpio1 11 GPIO_OPEN_DRAIN>;  /* CLK_CTL = 111 */
		
		led-gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
	};
};

&reg0 {
	status = "okay";
};

&reg1 {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

/* I2C полностью отключен, так как его пины (22 и 24) теперь заняты шиной SPI */
&i2c0 {
	status = "disabled";
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&pwm1 {
	status = "okay";
	pinctrl-0 = <&pwm1_default>;
	pinctrl-1 = <&pwm1_sleep>;
	pinctrl-names = "default", "sleep";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&cryptocell {
	status = "disabled";
};

&nfct {
	status = "disabled";
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio1 0 GPIO_ACTIVE_LOW>; /* CS = 100 */

	imu_spi: imu_spi@0 {
		compatible = "vnd,spi-device";
		spi-max-frequency = <8000000>; /* Оставляем 8MHz для стабильности */
		label = "imu-spi";
		reg = <0>;
	};
};
